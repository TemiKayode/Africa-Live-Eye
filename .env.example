# NASA FIRMS API key — free, register at:
# https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Without this, the app runs in demo mode with sample fire locations.
FIRMS_API_KEY=e7cb82fca38543e2940b523395b30ddf

# Mapbox access token — enables sub-meter (30–50 cm) Maxar satellite imagery (zoom 22).
# Free account at https://mapbox.com → Account → Access tokens
MAPBOX_TOKEN=

# Server port (default: 3000)
PORT=3000

# How often to refresh fire data from FIRMS in milliseconds (default: 3 hours)
FIRE_UPDATE_INTERVAL_MS=10800000
